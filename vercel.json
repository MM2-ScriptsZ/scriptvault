{
  "version": 2,
  "rewrites": [
    { "source": "/api/scripts/:id/views", "destination": "/api/views?id=:id" },
    { "source": "/api/scripts/:id",        "destination": "/api/script?id=:id" },
    { "source": "/api/scripts",            "destination": "/api/scripts" },
    { "source": "/api/stats",              "destination": "/api/stats" },
    { "source": "/api/admin/login",        "destination": "/api/login" },
    { "source": "/api/admin/change-password", "destination": "/api/change-password" },
    { "source": "/api/admin/scripts/:id",  "destination": "/api/script?id=:id" },
    { "source": "/api/admin/scripts",      "destination": "/api/delete-all" }
  ]
}
